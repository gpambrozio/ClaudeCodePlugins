#!/bin/bash
#
# swift wrapper — Injects sandbox isolation for SPM subcommands
#
# Reads the per-session sandbox path from the pointer file written by
# setup-sandbox.sh, then injects --cache-path for subcommands that accept
# SwiftPM flags (build, test, run). Other subcommands pass through unmodified.
#
# On first build invocation, seeds the sandbox SPM cache from the system
# cache using APFS copy-on-write clones (zero extra disk until writes diverge).

set -euo pipefail

SESSION_PID="${PPID:-$$}"
PATH_FILE="${TMPDIR:-/tmp}/claude-sandbox-$SESSION_PID"

if [[ ! -f "$PATH_FILE" ]]; then
    # No sandbox — pass through to real swift
    exec /usr/bin/swift "$@"
fi

SANDBOX_BASE=$(cat "$PATH_FILE")
SANDBOX_PKGS="$SANDBOX_BASE/packages"

case "${1:-}" in
    build|test|run)
        # Lazy SPM cache seeding — only on first build
        if [[ ! -f "$SANDBOX_PKGS/.seeded" ]]; then
            system_spm="$HOME/Library/Caches/org.swift.swiftpm"
            if [[ -d "$system_spm" ]]; then
                cp -cpR "$system_spm/" "$SANDBOX_PKGS/" 2>/dev/null || true
            fi
            touch "$SANDBOX_PKGS/.seeded"
        fi
        exec /usr/bin/swift "$@" \
            --cache-path "$SANDBOX_PKGS"
        ;;
    *)
        exec /usr/bin/swift "$@"
        ;;
esac
