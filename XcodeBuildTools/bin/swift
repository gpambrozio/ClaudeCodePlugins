#!/bin/bash
#
# swift wrapper — Injects sandbox isolation for SPM subcommands
#
# Shadows /usr/bin/swift via the plugin's bin/ directory on PATH, so both
# direct Claude invocations and nested calls from build scripts
# (Makefiles, fastlane, shell scripts, etc.) are sandboxed transparently.
#
# Resolves the per-session sandbox path from $CLAUDE_SESSION_ID (exported
# by the PreToolUse inject-session-id.py hook into every Bash command),
# then injects --cache-path for subcommands that accept SwiftPM flags
# (build, test, run). Other subcommands pass through unmodified.
#
# On first build invocation, seeds the sandbox SPM cache from the system
# cache using APFS copy-on-write clones (zero extra disk until writes diverge).

set -euo pipefail

SESSION_ID="${CLAUDE_SESSION_ID:-}"

if [[ -z "$SESSION_ID" ]]; then
    echo "[swift-wrapper] Warning: CLAUDE_SESSION_ID not set, running unsandboxed" >&2
    exec /usr/bin/swift "$@"
fi

SANDBOX_BASE="${TMPDIR:-/tmp}/claude-sandbox/$SESSION_ID"
SANDBOX_PKGS="$SANDBOX_BASE/packages"

case "${1:-}" in
    build|test|run)
        mkdir -p "$SANDBOX_PKGS"
        # Lazy SPM cache seeding — only on first build
        if [[ ! -f "$SANDBOX_PKGS/.seeded" ]]; then
            system_spm="$HOME/Library/Caches/org.swift.swiftpm"
            if [[ -d "$system_spm" ]]; then
                cp -cpR "$system_spm/" "$SANDBOX_PKGS/" 2>/dev/null || true
            fi
            touch "$SANDBOX_PKGS/.seeded"
        fi
        exec /usr/bin/swift "$@" \
            --cache-path "$SANDBOX_PKGS"
        ;;
    *)
        exec /usr/bin/swift "$@"
        ;;
esac
